# DeepSeek API key (free: register at platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# DeepL API key (free tier: 500k chars/month at deepl.com)
DEEPL_API_KEY=your-deepl-key-here

